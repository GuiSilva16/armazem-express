PORT=4000
JWT_SECRET=muda-isto-para-uma-string-aleatoria-longa
JWT_EXPIRES_IN=7d
DB_PATH=./database.sqlite
NODE_ENV=development

# URL do frontend (para redirects do Stripe)
FRONTEND_URL=http://localhost:5173

# Stripe (modo de teste) — dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs dos planos no Stripe (Product catalog → cada produto → Pricing)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# Envio de email (recuperação de palavra-passe) — opcional
# Gmail: SMTP_HOST=smtp.gmail.com, PORT=587, USER=teu@gmail.com, PASS=palavra-passe-de-app (16 letras)
# Mailtrap (teste): usa o host/porta/credenciais do teu inbox Mailtrap
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Armazém Express <noreply@armazem-express.pt>
